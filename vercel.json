{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd oer-hub && npm run build",
  "devCommand": "cd oer-hub && npm run dev",
  "installCommand": "cd oer-hub && npm ci",
  "outputDirectory": "oer-hub/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
